# Bradbury account private key used by the deploy script.
# The wallet must be funded via https://testnet-faucet.genlayer.foundation/
ACCOUNT_PRIVATE_KEY=

# Optional: recipient of protocol fees on paid assessments.
# Leave blank to default to the deployer address.
FEE_RECIPIENT=

# Optional: protocol fee in basis points (100 = 1%). Default: 100.
FEE_BPS=100
